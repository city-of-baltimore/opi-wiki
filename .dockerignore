# Keep the Fly/Docker build context lean: never ship generated output, VCS
# history, local envs, or caches into the image build.
.git
.gitignore
site/
overrides/.gitkeep
node_modules/
**/__pycache__/
*.pyc
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.DS_Store
notes/
tests/
.archive.scratch/
*.log
