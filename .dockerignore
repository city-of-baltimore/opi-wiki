# Keep the build context small and avoid copying host-only artifacts into the
# image (the container builds its own .venv and site/).
.git
.github
.env*
.venv
venv/
site/
notes/
.claude/
node_modules/
__pycache__/
**/__pycache__/
*.pyc
.mypy_cache/
.ruff_cache/
.pytest_cache/
.DS_Store
**/.DS_Store
