#!/usr/bin/env bash
#
# Pre-push gate for opi-wiki.
#
# Hosted CI runs the `ci` plan only — static checks, contracts, and security.
# The test suite, the strict MkDocs build, and the built-site checks live here.
# That is deliberate (patapsco/docs/app-consistency-standard.md, §4), and it
# means THIS HOOK IS THE ONLY BACKSTOP for a broken test. Do not bypass it
# casually; `git push --no-verify` skips the entire suite.
#
# Install with: ./scripts/install-hooks.sh

set -euo pipefail

# Nothing to verify when every ref being pushed is a deletion.
all_deletions=true
while read -r _local_ref local_sha _remote_ref _remote_sha; do
  if [ "${local_sha}" != "0000000000000000000000000000000000000000" ]; then
    all_deletions=false
  fi
done

if [ "${all_deletions}" = true ]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

echo "pre-push: running the prepush verification plan (tests, strict build, built-site checks)."
echo "pre-push: hosted CI does NOT run these — this hook is the backstop."

exec ./scripts/verify.sh --plan prepush
