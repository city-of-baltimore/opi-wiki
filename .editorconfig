# Shared editor defaults. Keep in step with ruff (line-length 100) and the
# repository style guide in STYLE.md.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[*.py]
indent_size = 4

[*.md]
# Markdown uses trailing whitespace for hard line breaks.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
